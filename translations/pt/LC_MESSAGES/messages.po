#: ui/templates/em/hybride.html:33
msgid ""
"Assistant IA conversationnel connecté en temps réel aux tirages officiels"
" EuroMillions. Analyse factuelle, zéro hallucination."
msgstr ""
"Assistente IA conversacional conectado em tempo real aos sorteios "
